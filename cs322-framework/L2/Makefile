
CPP_FILES		:= $(shell find src -name "*.cpp" -type f)
OBJ_FILES		:= $(patsubst src/%.cpp,obj/%.o,$(CPP_FILES))
CC_FLAGS		:= --std=c++2a -I./src -I../lib/PEGTL/include -I../lib -I../util -g3 -DDEBUG -pedantic -pedantic-errors -Werror=pedantic
CC				:= clang++
PL_CLASS		:= L2
COMPILER 		:= bin/$(PL_CLASS)
TEST_DIR		:= tests
OUT_DIR			:= out/
BUILD_DIR		:= build
ROOT_DIR		:= ..
RUNTIME			:= $(ROOT_DIR)/lib/runtime.c
INTERFERENCE_DIR:= $(TEST_DIR)/interference
LIVENESS_DIR	:= $(TEST_DIR)/liveness
SPILLING_DIR	:= $(TEST_DIR)/spill

build: dirs $(COMPILER)

all: dirs $(COMPILER)

dirs: obj bin

obj:
	mkdir -p $@

bin:
	mkdir -p $@

$(COMPILER): $(OBJ_FILES)
	$(CC) $(LD_FLAGS) -o $@ $^

obj/%.o: src/%.cpp
	@mkdir -p $(dir $@)
	$(CC) $(CC_FLAGS) -c -o $@ $<

compile:
	python3 ../scripts/compile.py $(ROOT_DIR) $(PL_CLASS) $(FILE) $(BUILD_DIR) $(RUNTIME)

run:
	python3 ../scripts/compile_and_run.py $(ROOT_DIR) $(PL_CLASS) $(FILE) $(BUILD_DIR) $(RUNTIME)

test:
	python3 ../scripts/test_compiler.py $(ROOT_DIR) $(PL_CLASS) $(TEST_DIR) $(BUILD_DIR) $(RUNTIME) --out $(OUT_DIR)

interference:
	python3 ../scripts/generate_interference.py $(COMPILER) $(FILE)

test_interference:
	python3 ../scripts/test_interference.py $(COMPILER) $(INTERFERENCE_DIR) --out $(OUT_DIR)/interf/

liveness:
	python3 ../scripts/generate_liveness.py $(COMPILER) $(FILE)

test_liveness:
	python3 ../scripts/test_liveness.py $(COMPILER) $(LIVENESS_DIR) --out $(OUT_DIR)/liv/

spilling:
	python3 ../scripts/generate_spilling.py $(COMPILER) $(FILE)

test_spilling:
	python3 ../scripts/test_spilling.py $(COMPILER) $(SPILLING_DIR) --out $(OUT_DIR)/spill/

copy_instructor_bin:
	mkdir -p bin ;
	cp .bin/* bin/ ;

clean:
	rm -fr bin obj *.out *.o core.* build/ out/

.PHONY: compiler all dirs bin $(COMPILER) test test_fast copy_instructor_bin clean

